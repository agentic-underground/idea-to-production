digraph FoundryArch {
  rankdir=TB;
  bgcolor="transparent";
  splines=spline;
  ranksep=0.55;
  nodesep=0.30;
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11, margin="0.20,0.12"];
  edge [fontname="Helvetica", fontsize=10, color="#444444", penwidth=1.3];

  roadmap [label="ROADMAP.md\n20 items  ·  5 done  ·  15 pending", fillcolor="#fff8c5", color="#9a6700", fontname="Helvetica-Bold", fontsize=12, margin="0.26,0.16"];

  lead [label="FOUNDRY LEAD ENGINEER\nread full roadmap  ·  determine stack\nidentify shared infrastructure\ndecompose items into tasks\nestimate token budget", fillcolor="#cfe1ff", color="#1f6feb", fontname="Helvetica-Bold", margin="0.24,0.14"];

  subgraph cluster_phase {
    label="PHASE_POOL  (lifecycle agents + reviewers)";
    fontname="Helvetica-Bold"; fontsize=11; color="#0969da"; bgcolor="#eef4ff"; style="rounded,dashed"; margin=14;
    phase [label="ds-step-0  →  ds-step-9\n+ ds-step-story-tests\n+ foundry-reviewer × 8 roles", fillcolor="#cfe1ff", color="#1f6feb", margin="0.24,0.14"];
  }

  subgraph cluster_handler {
    label="VALUE_HANDLER_POOL  (language and framework experts)";
    fontname="Helvetica-Bold"; fontsize=11; color="#1a7f37"; bgcolor="#dafbe1"; style="rounded,dashed"; margin=14;
    // Row 1 (4 handlers)
    h_py [label="handler\npython", fillcolor="#caf5c0", color="#1a7f37"];
    h_react [label="handler\nreact", fillcolor="#caf5c0", color="#1a7f37"];
    h_css [label="handler\ncss / scss", fillcolor="#caf5c0", color="#1a7f37"];
    h_js [label="handler\njs / ts", fillcolor="#caf5c0", color="#1a7f37"];
    // Row 2 (3 handlers)
    h_fast [label="handler\nfastapi", fillcolor="#caf5c0", color="#1a7f37"];
    h_play [label="handler\nplaywright", fillcolor="#caf5c0", color="#1a7f37"];
    h_arch [label="handler\narchitect", fillcolor="#caf5c0", color="#1a7f37"];
    { rank=same; h_py; h_react; h_css; h_js; }
    { rank=same; h_fast; h_play; h_arch; }
    // Invisible alignment edges to keep rows separate
    h_py -> h_fast [style=invis];
    h_react -> h_play [style=invis];
    h_css -> h_arch [style=invis];
  }

  ledger [label="IDEA_COST.jsonl\ntoken estimate  ·  actual  ·  variance", fillcolor="#fce8ff", color="#8250df", fontname="Helvetica-Bold", margin="0.22,0.14"];

  roadmap -> lead;
  lead -> phase;
  lead -> ledger [label="  estimate  ", fontname="Helvetica-Bold"];
  phase -> h_py [style=dotted, arrowhead=none, color="#1a7f37"];
  phase -> h_react [style=dotted, arrowhead=none, color="#1a7f37"];
  phase -> h_css [style=dotted, arrowhead=none, color="#1a7f37"];
  phase -> h_js [style=dotted, arrowhead=none, color="#1a7f37"];
  phase -> ledger [label="  actual  ", fontname="Helvetica-Bold"];
}
