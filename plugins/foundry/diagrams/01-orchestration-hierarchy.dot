digraph OrchestrationHierarchyA {
  bgcolor="transparent"
  rankdir=TB
  newrank=true
  ranksep=0.40
  nodesep=0.30
  node [shape=box, style="filled,rounded", fillcolor="#1e1e2e", color="#9aa2c0",
        fontcolor="#e6e9f0", fontname="DejaVu Sans", penwidth=1.4, margin="0.24,0.15"]
  edge [color="#9aa2c0", fontcolor="#7c84b8", penwidth=1.4, arrowsize=0.8]

  // ---- ORCHESTRATION altitude (3 nodes — the widest band, highest authority) ----
  subgraph cluster_orch {
    label=""
    labeljust="l"
    color="#5a5a72"
    style="dashed,rounded"
    penwidth=1.2
    margin=16

    // band header chip: bright text rides a filled dark slab (dual-ground safe)
    hdr_orch [shape=box, style="filled,rounded", fillcolor="#2a2a3c", color="#7aa2f7",
              penwidth=1.4, margin="0.16,0.08",
              label=<<b><font point-size="13">ORCHESTRATION</font></b>>]

    founder [label=<<b>founder (COO)</b><br/><font color="#b8bed0" point-size="10">turns an idea into a value-stationed path · staffs the line</font>>,
             color="#7aa2f7", penwidth=2.0]
    builder_lead [label=<<b>builder-lead</b><br/><font color="#b8bed0" point-size="10">ingests ROADMAP · tiers + budgets · emits FOUNDRY_PLAN.md</font>>]
    lifecycle [label=<<b>lifecycle-orchestrator</b><br/><font color="#b8bed0" point-size="10">drives ONE item through steps 0–9 + story · enforcing gates</font>>]

    hdr_orch -> founder [style=invis]
  }

  // ---- EXECUTION altitude (1 node — mid altitude) ----
  subgraph cluster_exec {
    label=""
    labeljust="l"
    color="#5a5a72"
    style="dashed,rounded"
    penwidth=1.2
    margin=16

    hdr_exec [shape=box, style="filled,rounded", fillcolor="#2a2a3c", color="#9aa2c0",
              penwidth=1.4, margin="0.16,0.08",
              label=<<b><font point-size="12">EXECUTION</font></b>>]

    execution [label=<<b>ds-step-* + handler-*</b><br/><font color="#b8bed0" point-size="10">do the station work — value-handlers staff stations by stack</font>>]

    hdr_exec -> execution [style=invis]
  }

  // ---- GATE altitude (1 node — lowest, the adversarial floor) ----
  subgraph cluster_gate {
    label=""
    labeljust="l"
    color="#5a5a72"
    style="dashed,rounded"
    penwidth=1.2
    margin=16

    hdr_gate [shape=box, style="filled,rounded", fillcolor="#2a2a3c", color="#bb9af7",
              penwidth=1.4, margin="0.16,0.08",
              label=<<b><font point-size="11">GATE</font></b>>]

    reviewer [label=<<b>reviewer</b><br/><font color="#b8bed0" point-size="10">adversarial gate panel: PASS / NEEDS_REVISION / BLOCK</font>>,
              fillcolor="#2a2a3c", color="#bb9af7", penwidth=2.0]

    hdr_gate -> reviewer [style=invis]
  }

  // ---- one chain of command, top to bottom ----
  founder -> builder_lead -> lifecycle -> execution -> reviewer [weight=10]
}
