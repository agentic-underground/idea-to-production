#!/usr/bin/env bash
# flow-mcp — launcher the flow plugin registers (see the plugin-root .mcp.json).
# It finds a Ruby >= 3.3.8 and execs the interpreted stdio MCP server
# (exe/flow-mcp); the plugin passes `--mcp`.
#
# WHY NO BINARY: flow-mcp was re-homed from a compiled Rust binary to a Ruby
# reference precisely to kill the compiled-artifact failure modes — release-sync
# friction, stale binary caches, undead binaries, and zero call visibility. An
# interpreted server has NO artifact-drift: there is nothing to download, pin,
# checksum, or cache. See plugins/foundry/knowledge/architecture/mcp-language-choice.md.
#
# RUNTIME: Ruby standard library only (>= 3.3.8). On the Debian-13 fleet the system
# `ruby` already satisfies this; elsewhere a Homebrew/rbenv/asdf Ruby works. If no
# compliant Ruby is found we exit non-zero pointing at the markdown fallback runbook
# (the /flow:flow-by-hand skill) rather than failing silently.
#
# CWD-INDEPENDENCE: the server resolves its roadmap from a RELATIVE `.i2p/roadmap`
# against its CWD unless given `--roadmap`. The harness may spawn this launcher from
# any directory, which would silently yield an empty board. So we walk up from $PWD
# to the project root (the dir holding `.i2p/roadmap/`) and inject an ABSOLUTE
# `--roadmap` (and a root-anchored `--data`) — unless the caller already passed them.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FS_DIR="$(dirname "$SCRIPT_DIR")"          # <plugin>/flow-mcp
EXE="$FS_DIR/exe/flow-mcp"
MIN_RUBY="3.3.8"
RUNBOOK="/flow:flow-by-hand"               # markdown fallback skill

log() { printf 'flow-mcp: %s\n' "$*" >&2; }

# True iff candidate ruby's RUBY_VERSION >= MIN_RUBY (asked of the interpreter itself).
ruby_ok() { "$1" -e 'exit(Gem::Version.new(RUBY_VERSION) >= Gem::Version.new(ARGV[0]) ? 0 : 1)' "$MIN_RUBY" >/dev/null 2>&1; }

# First Ruby >= MIN_RUBY among $FLOW_MCP_RUBY, the distro names, and the common
# version-manager / Homebrew shims. Prints its absolute path, or fails.
find_ruby() {
  local c
  for c in "${FLOW_MCP_RUBY:-}" ruby ruby3.3 ruby3.4 \
           /opt/homebrew/opt/ruby/bin/ruby /usr/local/opt/ruby/bin/ruby \
           "${HOME}/.rbenv/shims/ruby" "${HOME}/.asdf/shims/ruby"; do
    [ -n "$c" ] || continue
    command -v "$c" >/dev/null 2>&1 || continue
    if ruby_ok "$c"; then command -v "$c"; return 0; fi
  done
  return 1
}

# Walk up from $PWD to the nearest ancestor containing `.i2p/roadmap/`.
find_project_root() {
  local d="$PWD"
  while [ -n "$d" ] && [ "$d" != "/" ]; do
    [ -d "$d/.i2p/roadmap" ] && { printf '%s' "$d"; return 0; }
    d="$(dirname "$d")"
  done
  [ -d "/.i2p/roadmap" ] && { printf '/'; return 0; }
  return 1
}

# Anchor the server to the project root: absolute --roadmap (+ root --data), but
# only for flags the caller did not already pass. Sets the global array INJECT.
compute_injected_args() {
  INJECT=()
  local root have_roadmap=0 have_data=0 a
  for a in "$@"; do
    case "$a" in --roadmap) have_roadmap=1 ;; --data) have_data=1 ;; esac
  done
  root="$(find_project_root 2>/dev/null || true)"
  [ -n "$root" ] && [ -d "$root/.i2p/roadmap" ] || return 0
  [ "$have_roadmap" = 0 ] && INJECT+=(--roadmap "$root/.i2p/roadmap")
  [ "$have_data" = 0 ] && INJECT+=(--data "$root/.flow")
}

# Human-readable health report so a broken launch is diagnosable, not silently empty.
doctor() {
  local rb root
  echo "flow-mcp --doctor (Ruby reference)"
  echo "  server         : $EXE"
  if rb="$(find_ruby)"; then
    echo "  ruby           : $rb ($("$rb" -e 'print RUBY_VERSION')) >= $MIN_RUBY ✓"
  else
    echo "  ruby           : NONE >= $MIN_RUBY found — use the fallback runbook ($RUNBOOK)"
  fi
  if root="$(find_project_root 2>/dev/null)"; then
    echo "  project root   : $root"
    echo "  roadmap tree   : $root/.i2p/roadmap ($(find "$root/.i2p/roadmap" -maxdepth 2 -name '*.md' ! -name 'README.md' 2>/dev/null | wc -l | tr -d ' ') item file(s))"
  else
    echo "  project root   : NOT FOUND walking up from $PWD (no .i2p/roadmap/ ancestor) — board would be empty"
  fi
  exit 0
}

main() {
  INJECT=()
  case "${1:-}" in
    --doctor) doctor ;; # exits 0
    --ensure-binary)
      # Back-compat no-op for any SessionStart pre-warm caller: there is no binary
      # to fetch. Confirm a compliant Ruby is present (cheap) and exit 0 regardless.
      if find_ruby >/dev/null 2>&1; then log "ruby ready (>= $MIN_RUBY)"; else log "no Ruby >= $MIN_RUBY; fallback runbook is $RUNBOOK"; fi
      exit 0
      ;;
  esac

  local rb
  if ! rb="$(find_ruby)"; then
    log "no Ruby >= $MIN_RUBY found (tried \$FLOW_MCP_RUBY, ruby, ruby3.3, ruby3.4, Homebrew/rbenv/asdf shims)."
    log "install Ruby >= $MIN_RUBY — Debian/Ubuntu: 'apt-get install ruby'; macOS: 'brew install ruby'; or rbenv/asdf —"
    log "or use the markdown fallback runbook $RUNBOOK (the agent operates the .flow files by hand; slower, no server)."
    exit 1
  fi

  compute_injected_args "$@"
  exec "$rb" "$EXE" ${INJECT[@]+"${INJECT[@]}"} "$@"
}

main "$@"
