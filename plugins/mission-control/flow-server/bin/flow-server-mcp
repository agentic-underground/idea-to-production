#!/usr/bin/env bash
# flow-server-mcp — the MCP launcher the mission-control plugin registers (see the
# plugin-root .mcp.json). It obtains the flow-server binary WITHOUT requiring a Rust
# toolchain on the destination machine, then execs it (the plugin passes `--mcp`).
#
# Resolution ladder (first that succeeds wins):
#   1. CACHED   — a previously-retrieved binary, in a cache dir keyed on the pinned tag
#                 AND the pinned checksum, whose SHA256 still matches the COMMITTED pin.
#   2. RETRIEVE — download the prebuilt release asset for this platform from GitHub
#                 Releases, VERIFY it against the committed SHA256 (bin/SHA256SUMS),
#                 cache, exec.
#   3. BUILD    — DEV fallback only: if cargo is present and the source is alongside,
#                 build --release from source. (A contributor's machine; never required
#                 on a destination.)
#   4. ERROR    — none worked: print an actionable message and exit non-zero.
#
# DETERMINISM / INTEGRITY: we PIN a specific release (bin/RELEASE) and run a retrieved
# binary ONLY if its SHA256 matches the checksum committed in bin/SHA256SUMS — never a
# checksum fetched at runtime, and never an arbitrary "newest cached" binary. Two things
# defeat the staleness that made this unreliable (defect [92]):
#   * the cache dir is keyed on the pinned tag PLUS a fingerprint of the committed sum, so
#     a re-cut/bumped pin lands in a NEW dir — a stale dir is never selected again; and
#   * every cache hit is re-verified against the committed sum, so a re-cut tag (same name,
#     different bytes) can never satisfy the new pin from an old cache.
# A mismatch is refused (never executed) and falls through to the build fallback. This
# mirrors the marketplace's pinned-release discipline (verify-prereqs.sh §K: no floating tags).
#
# CWD-INDEPENDENCE: the flow-server resolves its roadmap from a RELATIVE `.i2p/roadmap`
# against its CWD unless given `--roadmap`. The harness may spawn this launcher from any
# directory, which would silently yield an empty board. So we walk up from $PWD to the
# project root (the dir holding `.i2p/roadmap/`) and inject an ABSOLUTE `--roadmap` (and a
# root-anchored `--data`) — unless the caller already passed them. This is why a stale
# binary, not a wrong CWD, is the only remaining way the board can come up empty.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# CLAUDE_PLUGIN_ROOT (set by the harness for plugin surfaces) = the mission-control plugin
# root; else derive it (this script lives at <plugin>/flow-server/bin/flow-server-mcp).
# NOTE: this is the PLUGIN dir, NOT the user's project root — the project root is found by
# the $PWD walk-up below, never from CLAUDE_PLUGIN_ROOT.
PLUGIN="${CLAUDE_PLUGIN_ROOT:-$(dirname "$(dirname "$SCRIPT_DIR")")}"
FS_DIR="$PLUGIN/flow-server"
REPO="agentic-underground/idea-to-production"
RELEASE_TAG="$(tr -d '[:space:]' < "$SCRIPT_DIR/RELEASE" 2>/dev/null || true)"
SUMS_FILE="$SCRIPT_DIR/SHA256SUMS"
CACHE_BASE="${XDG_CACHE_HOME:-$HOME/.claude}/flow-server"
PREWARM_LOG="$CACHE_BASE/prewarm.log"
# retrieve() is always called as `bin="$(retrieve)"` — a command substitution, i.e. a SUBSHELL.
# A variable it sets cannot reach the parent, so it records its failure reason to this file and
# the parent reads it back with read_reason after the call. (File writes DO survive a subshell.)
REASON_FILE="$CACHE_BASE/.last-reason"

log() { printf 'flow-server-mcp: %s\n' "$*" >&2; }
set_reason() { mkdir -p "$CACHE_BASE" 2>/dev/null || true; printf '%s' "$*" >"$REASON_FILE" 2>/dev/null || true; }
read_reason() { cat "$REASON_FILE" 2>/dev/null || true; }

# Append a timestamp-free diagnostic line to the prewarm log (best-effort; never fatal).
# Failures during a background pre-warm are otherwise invisible — this makes them readable.
prewarm_log() {
  mkdir -p "$CACHE_BASE" 2>/dev/null || return 0
  printf 'flow-server prewarm[%s]: %s\n' "$RELEASE_TAG" "$*" >>"$PREWARM_LOG" 2>/dev/null || true
}

# uname → the Rust target triple used in release asset names.
target_triple() {
  local os arch
  case "$(uname -s 2>/dev/null)" in
    Linux)                os="unknown-linux-gnu" ;;
    Darwin)               os="apple-darwin" ;;
    MINGW*|MSYS*|CYGWIN*) os="pc-windows-msvc" ;;
    *) return 1 ;;
  esac
  case "$(uname -m 2>/dev/null)" in
    x86_64|amd64)  arch="x86_64" ;;
    arm64|aarch64) arch="aarch64" ;;
    *) return 1 ;;
  esac
  printf '%s-%s' "$arch" "$os"
}

asset_name() {  # → the release asset file name for this platform
  local triple ext
  triple="$(target_triple)" || return 1
  ext=""; case "$triple" in *windows*) ext=".exe" ;; esac
  printf 'flow-server-%s%s' "$triple" "$ext"
}

sha256_of() {  # <file> → lowercase hex digest (or non-zero if no tool)
  if command -v sha256sum >/dev/null 2>&1; then sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then shasum -a 256 "$1" | awk '{print $1}'
  else return 1; fi
}

pinned_sum_for() {  # <asset> → the committed 64-hex SHA256 for that asset, if any
  [ -f "$SUMS_FILE" ] || return 0
  # Skip comment/blank lines and accept ONLY a well-formed 64-hex digest — a security-critical
  # pin parser must reject a malformed pin (e.g. a '#' from an example comment line), never
  # return it as if it were a checksum.
  awk -v a="$1" '
    /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
    ($2==a || $2=="*"a) && $1 ~ /^[0-9a-fA-F]{64}$/ { print $1; exit }
  ' "$SUMS_FILE" 2>/dev/null || true
}

# The cache dir for the current pin: keyed on the tag AND a 12-hex fingerprint of the
# committed checksum, so a re-cut or bumped pin lands in a fresh dir and a stale dir is
# never re-selected. <expected-sum> may be empty (→ dir keyed on tag alone).
cache_dir() {  # <expected-sum>
  local fp="${1:0:12}"
  printf '%s/%s%s' "$CACHE_BASE" "${RELEASE_TAG:-unpinned}" "${fp:+-$fp}"
}

# Print a verified binary path, or fail (→ build fallback). Never execs an unverified file.
retrieve() {
  local ext asset cache bin expected url tmp got
  set_reason ""   # clear any reason from a prior call (set_reason mkdir's $CACHE_BASE first)
  asset="$(asset_name)" || { set_reason "unsupported platform ($(uname -sm 2>/dev/null))"; return 1; }
  ext=""; case "$asset" in *.exe) ext=".exe" ;; esac
  expected="$(pinned_sum_for "$asset")"
  cache="$(cache_dir "$expected")"
  bin="$cache/flow-server${ext}"

  # Cached and still matching the COMMITTED pin? Use it (no network).
  if [ -n "$expected" ] && [ -x "$bin" ]; then
    got="$(sha256_of "$bin" 2>/dev/null || true)"
    [ "$got" = "$expected" ] && { printf '%s' "$bin"; return 0; }
  fi

  # Can only retrieve safely with both a pinned tag and a pinned checksum.
  [ -n "$RELEASE_TAG" ] && [ -n "$expected" ] || { set_reason "no pin (tag/checksum) for this platform — bin/SHA256SUMS not finalized for ${asset}?"; return 1; }
  command -v curl >/dev/null 2>&1 || { set_reason "curl not available"; return 1; }

  url="https://github.com/${REPO}/releases/download/${RELEASE_TAG}/${asset}"
  mkdir -p "$cache" 2>/dev/null || { set_reason "cannot create cache dir"; return 1; }
  tmp="$cache/.dl.$$"
  log "retrieving ${asset} from the ${RELEASE_TAG} release…"
  if ! curl -fsSL --connect-timeout 10 --max-time 120 "$url" -o "$tmp" 2>/dev/null; then
    rm -f "$tmp"; set_reason "download failed (offline or asset missing): $url"; return 1
  fi
  got="$(sha256_of "$tmp" 2>/dev/null || true)"
  if [ "$got" != "$expected" ]; then
    rm -f "$tmp"
    set_reason "SHA256 MISMATCH for ${asset} (pinned ${expected:-∅}, got ${got:-∅}) — refused"
    log "REFUSING ${asset}: SHA256 mismatch (pinned ${expected:-∅}, got ${got:-∅})."
    return 1
  fi
  chmod +x "$tmp" 2>/dev/null || true
  mv -f "$tmp" "$bin" 2>/dev/null || { rm -f "$tmp"; set_reason "cannot install cached binary"; return 1; }
  printf '%s' "$bin"
}

# DEV fallback: build from the source shipped beside this launcher. Requires cargo.
build_from_source() {
  command -v cargo >/dev/null 2>&1 || return 1
  [ -f "$FS_DIR/Cargo.toml" ] || return 1
  log "no verified release binary for this platform; building from source with cargo (dev fallback)…"
  cargo build --release --manifest-path "$FS_DIR/Cargo.toml" --bin flow-server >&2 || return 1
  printf '%s' "$FS_DIR/target/release/flow-server"
}

# Walk up from $PWD to the project root — the nearest ancestor containing a `.i2p/roadmap/`
# directory. Prints the root path, or fails. (The plugin dir is NOT the project root, so the
# walk-up from the spawn CWD is the only correct source — see header.)
find_project_root() {
  local d="$PWD"
  while [ -n "$d" ] && [ "$d" != "/" ]; do
    [ -d "$d/.i2p/roadmap" ] && { printf '%s' "$d"; return 0; }
    d="$(dirname "$d")"
  done
  [ -d "/.i2p/roadmap" ] && { printf '/'; return 0; }
  return 1
}

# --doctor: a human-readable health report so a broken/stale launch is diagnosable instead of
# silently empty. Prints the pin, the expected vs cached checksum (match/mismatch), the cache
# dir, and the resolved project root + whether its roadmap tree was found. Always exits 0.
doctor() {
  local asset expected cache bin got root
  echo "flow-server-mcp --doctor"
  echo "  plugin dir     : $PLUGIN"
  echo "  pinned tag     : ${RELEASE_TAG:-<unset>}"
  asset="$(asset_name 2>/dev/null || echo '<unsupported platform>')"
  echo "  platform asset : $asset"
  expected="$(pinned_sum_for "$asset" 2>/dev/null || true)"
  echo "  pinned SHA256  : ${expected:-<none committed>}"
  cache="$(cache_dir "$expected")"
  bin="$cache/flow-server"; [ -e "${bin}.exe" ] && bin="${bin}.exe"
  echo "  cache dir      : $cache"
  if [ -x "$bin" ]; then
    got="$(sha256_of "$bin" 2>/dev/null || echo '<no sha tool>')"
    if [ -z "$expected" ]; then
      echo "  cached binary  : present (SHA256 ${got}) — but NO checksum is committed for ${asset} yet (bootstrap window), so it can't be pin-verified"
    elif [ "$got" = "$expected" ]; then
      echo "  cached binary  : present — SHA256 MATCHES the pin ✓"
    else
      echo "  cached binary  : present — SHA256 ${got} does NOT match the pin ✗ (will re-retrieve)"
    fi
  else
    echo "  cached binary  : none cached yet (will retrieve on launch)"
  fi
  if root="$(find_project_root 2>/dev/null)"; then
    echo "  project root   : $root"
    echo "  roadmap tree   : $root/.i2p/roadmap ($(find "$root/.i2p/roadmap" -maxdepth 2 -name '*.md' ! -name 'README.md' 2>/dev/null | wc -l | tr -d ' ') item file(s))"
  else
    echo "  project root   : NOT FOUND walking up from $PWD (no .i2p/roadmap/ ancestor) — board would be empty"
  fi
  [ -f "$PREWARM_LOG" ] && { echo "  last prewarm   :"; tail -n 3 "$PREWARM_LOG" 2>/dev/null | sed 's/^/    /'; }
  exit 0
}

# Compose the extra args that anchor the server to the project root: an absolute --roadmap
# (and a root-anchored --data), but ONLY for flags the caller did not already pass. Sets the
# global array INJECT.
compute_injected_args() {
  INJECT=()
  local root have_roadmap=0 have_data=0 a
  for a in "$@"; do
    case "$a" in --roadmap) have_roadmap=1 ;; --data) have_data=1 ;; esac
  done
  root="$(find_project_root 2>/dev/null || true)"
  [ -n "$root" ] && [ -d "$root/.i2p/roadmap" ] || return 0
  [ "$have_roadmap" = 0 ] && INJECT+=(--roadmap "$root/.i2p/roadmap")
  [ "$have_data" = 0 ] && INJECT+=(--data "$root/.flow")
}

main() {
  local bin=""
  INJECT=()

  case "${1:-}" in
    --doctor) doctor ;;  # exits 0
    --ensure-binary)
      # Pre-warm mode (background SessionStart prewarm): retrieve + SHA-verify + cache the
      # release binary, then exit 0 — NEVER start the server and NEVER fall back to a cargo
      # build (a multi-minute build must not run in a fresh session's background). On failure
      # we still exit 0 (the real launch resolves it lazily), but we LOG the reason to
      # $PREWARM_LOG so a failed pre-warm is diagnosable rather than silent.
      if bin="$(retrieve)" && [ -n "$bin" ]; then
        log "pre-warmed ${bin}"; prewarm_log "OK — cached ${bin}"
      else
        RETRIEVE_REASON="$(read_reason)"
        case "$RETRIEVE_REASON" in
          *MISMATCH*) prewarm_log "REFUSED — ${RETRIEVE_REASON}. The pin and the published asset disagree." ;;
          *download*) prewarm_log "deferred — ${RETRIEVE_REASON}. Will resolve on next launch." ;;
          *)          prewarm_log "deferred — ${RETRIEVE_REASON:-unknown}." ;;
        esac
        log "pre-warm skipped — ${RETRIEVE_REASON:-no verified release binary for this platform yet}; resolved lazily on launch."
      fi
      exit 0
      ;;
  esac

  if bin="$(retrieve)" && [ -n "$bin" ]; then :
  elif bin="$(build_from_source)" && [ -n "$bin" ]; then :
  else
    log "could not obtain the flow-server binary for this platform ($(uname -sm 2>/dev/null)): $(read_reason || echo unknown)."
    log "expected a pinned release at https://github.com/${REPO}/releases/tag/${RELEASE_TAG:-<unset>},"
    log "or a Rust toolchain (https://rustup.rs) for the source-build fallback."
    exit 1
  fi

  compute_injected_args "$@"
  exec "$bin" ${INJECT[@]+"${INJECT[@]}"} "$@"
}

main "$@"
