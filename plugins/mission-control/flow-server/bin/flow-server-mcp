#!/usr/bin/env bash
# flow-server-mcp — the MCP launcher the mission-control plugin registers (see the
# plugin-root .mcp.json). It obtains the flow-server binary WITHOUT requiring a Rust
# toolchain on the destination machine, then execs it (the plugin passes `--mcp`).
#
# Resolution ladder (first that succeeds wins):
#   1. RESOLVE  — ask GitHub which release is LATEST (the `releases/latest` redirect; API
#                 fallback). We always track latest — there is NO committed version pin.
#   2. CACHED   — a previously-retrieved binary for that latest tag whose SHA256 still
#                 matches the release's own published SHA256SUMS (no network beyond resolve).
#   3. RETRIEVE — download the prebuilt release asset for this platform AND that release's
#                 own SHA256SUMS, VERIFY the asset against it, cache, exec.
#   4. CACHED-OFFLINE — resolve failed (offline): exec the newest cached binary that still
#                 verifies against its cached SHA256SUMS (last-known-good).
#   5. BUILD    — DEV fallback only: if cargo is present and the source is alongside, build
#                 --release from source. (A contributor's machine; never required on a dest.)
#   6. ERROR    — none worked: print an actionable message and exit non-zero.
#
# SECURITY / INTEGRITY: we no longer pin a specific version — we always fetch the LATEST
# release. A retrieved binary is still run ONLY if its SHA256 matches the checksum the
# release itself publishes in its SHA256SUMS asset (defence-in-depth over the TLS transport):
# a mismatch is refused (never executed) and falls through to the build fallback. Tracking
# latest deliberately trades away the reproducibility / malicious-publish protection a
# committed pin gives — an explicit, owner-chosen posture (see flow-server/README.md).
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# CLAUDE_PLUGIN_ROOT (set by the harness for plugin surfaces) = the mission-control plugin
# root; else derive it (this script lives at <plugin>/flow-server/bin/flow-server-mcp).
PLUGIN="${CLAUDE_PLUGIN_ROOT:-$(dirname "$(dirname "$SCRIPT_DIR")")}"
FS_DIR="$PLUGIN/flow-server"
REPO="agentic-underground/idea-to-production"
CACHE_ROOT="${XDG_CACHE_HOME:-$HOME/.claude}/flow-server"

log() { printf 'flow-server-mcp: %s\n' "$*" >&2; }

# uname → the Rust target triple used in release asset names.
target_triple() {
  local os arch
  case "$(uname -s 2>/dev/null)" in
    Linux)                os="unknown-linux-gnu" ;;
    Darwin)               os="apple-darwin" ;;
    MINGW*|MSYS*|CYGWIN*) os="pc-windows-msvc" ;;
    *) return 1 ;;
  esac
  case "$(uname -m 2>/dev/null)" in
    x86_64|amd64)  arch="x86_64" ;;
    arm64|aarch64) arch="aarch64" ;;
    *) return 1 ;;
  esac
  printf '%s-%s' "$arch" "$os"
}

sha256_of() {  # <file> → lowercase hex digest (or non-zero if no tool)
  if command -v sha256sum >/dev/null 2>&1; then sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then shasum -a 256 "$1" | awk '{print $1}'
  else return 1; fi
}

sum_for() {  # <sums-file> <asset> → the published 64-hex SHA256 for that asset, if any
  [ -f "$1" ] || return 0
  # Skip comment/blank lines and accept ONLY a well-formed 64-hex digest — an integrity
  # parser must reject a malformed line (e.g. a '#' from a comment), never return it as if
  # it were a checksum.
  awk -v a="$2" '
    /^[[:space:]]*#/ || /^[[:space:]]*$/ { next }
    ($2==a || $2=="*"a) && $1 ~ /^[0-9a-fA-F]{64}$/ { print $1; exit }
  ' "$1" 2>/dev/null || true
}

# Resolve the LATEST release tag from GitHub WITHOUT jq: follow the `releases/latest`
# redirect, whose effective URL ends with /releases/tag/<TAG>. API fallback for environments
# that don't expose the redirect. Prints the tag, or fails (→ offline cache fallback).
resolve_latest_tag() {
  command -v curl >/dev/null 2>&1 || return 1
  local url tag=""
  url="$(curl -fsSL -o /dev/null -w '%{url_effective}' --connect-timeout 10 --max-time 30 \
        "https://github.com/${REPO}/releases/latest" 2>/dev/null || true)"
  case "$url" in
    */releases/tag/*) tag="${url##*/tag/}" ;;
  esac
  if [ -z "$tag" ]; then
    tag="$(curl -fsSL --connect-timeout 10 --max-time 30 \
          "https://api.github.com/repos/${REPO}/releases/latest" 2>/dev/null \
          | sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n1)"
  fi
  # Defensive: a tag is a git ref — it must never contain a path separator or whitespace
  # (it goes straight into a download URL path).
  case "$tag" in
    ''|*/*|*[[:space:]]*) return 1 ;;
  esac
  printf '%s' "$tag"
}

# Print a verified binary path for <tag>, or fail (→ next rung). Downloads the asset AND the
# release's own SHA256SUMS and verifies. Never execs an unverified file.
retrieve() {  # <tag>
  local tag="$1" triple ext asset cache bin sums expected url tmp got
  [ -n "$tag" ] || return 1
  triple="$(target_triple)" || return 1
  ext=""; case "$triple" in *windows*) ext=".exe" ;; esac
  asset="flow-server-${triple}${ext}"
  cache="$CACHE_ROOT/${tag}"
  bin="$cache/flow-server${ext}"
  sums="$cache/SHA256SUMS"

  # Cached binary + cached sums still matching? Use it (no network beyond resolve).
  expected="$(sum_for "$sums" "$asset")"
  if [ -n "$expected" ] && [ -x "$bin" ]; then
    got="$(sha256_of "$bin" 2>/dev/null || true)"
    [ "$got" = "$expected" ] && { printf '%s' "$bin"; return 0; }
  fi

  command -v curl >/dev/null 2>&1 || return 1
  mkdir -p "$cache" 2>/dev/null || return 1

  # Fetch the release's published SHA256SUMS — the integrity source of truth for this tag.
  if ! curl -fsSL --connect-timeout 10 --max-time 60 \
       "https://github.com/${REPO}/releases/download/${tag}/SHA256SUMS" -o "$cache/.sums.$$" 2>/dev/null; then
    rm -f "$cache/.sums.$$"; return 1
  fi
  expected="$(sum_for "$cache/.sums.$$" "$asset")"
  if [ -z "$expected" ]; then
    rm -f "$cache/.sums.$$"; log "no SHA256 for ${asset} in the ${tag} SHA256SUMS."; return 1
  fi

  url="https://github.com/${REPO}/releases/download/${tag}/${asset}"
  tmp="$cache/.dl.$$"
  log "retrieving ${asset} from the latest release (${tag})…"
  if ! curl -fsSL --connect-timeout 10 --max-time 120 "$url" -o "$tmp" 2>/dev/null; then
    rm -f "$tmp" "$cache/.sums.$$"; return 1
  fi
  got="$(sha256_of "$tmp" 2>/dev/null || true)"
  if [ "$got" != "$expected" ]; then
    rm -f "$tmp" "$cache/.sums.$$"
    log "REFUSING ${asset}: SHA256 mismatch (published ${expected:-∅}, got ${got:-∅})."
    return 1
  fi
  chmod +x "$tmp" 2>/dev/null || true
  mv -f "$tmp" "$bin" 2>/dev/null || { rm -f "$tmp" "$cache/.sums.$$"; return 1; }
  mv -f "$cache/.sums.$$" "$sums" 2>/dev/null || rm -f "$cache/.sums.$$"
  printf '%s' "$bin"
}

# Offline fallback: the newest cached tag whose binary still verifies against its cached
# SHA256SUMS (last-known-good). Used only when we cannot resolve the latest tag (no network).
newest_cached_verified() {
  local triple ext asset d bin sums expected got
  triple="$(target_triple)" || return 1
  ext=""; case "$triple" in *windows*) ext=".exe" ;; esac
  asset="flow-server-${triple}${ext}"
  [ -d "$CACHE_ROOT" ] || return 1
  for d in $(ls -1dt "$CACHE_ROOT"/*/ 2>/dev/null); do
    bin="${d}flow-server${ext}"; sums="${d}SHA256SUMS"
    [ -x "$bin" ] || continue
    expected="$(sum_for "$sums" "$asset")"
    [ -n "$expected" ] || continue
    got="$(sha256_of "$bin" 2>/dev/null || true)"
    [ "$got" = "$expected" ] && { printf '%s' "$bin"; return 0; }
  done
  return 1
}

# DEV fallback: build from the source shipped beside this launcher. Requires cargo.
build_from_source() {
  command -v cargo >/dev/null 2>&1 || return 1
  [ -f "$FS_DIR/Cargo.toml" ] || return 1
  log "no verified release binary for this platform; building from source with cargo (dev fallback)…"
  cargo build --release --manifest-path "$FS_DIR/Cargo.toml" --bin flow-server >&2 || return 1
  printf '%s' "$FS_DIR/target/release/flow-server"
}

main() {
  local tag bin=""
  tag="$(resolve_latest_tag || true)"

  # Pre-warm mode (for a background SessionStart prewarm): resolve latest + retrieve +
  # SHA-verify + cache, then exit 0 — NEVER start the server and NEVER fall back to a cargo
  # build (a multi-minute build must not run in the background of a fresh session). If the
  # latest release can't be resolved/verified for this platform, do nothing and exit 0
  # cleanly — the real launch resolves it lazily.
  if [ "${1:-}" = "--ensure-binary" ]; then
    if [ -n "$tag" ] && bin="$(retrieve "$tag")" && [ -n "$bin" ]; then
      log "pre-warmed ${bin}"
    else
      log "pre-warm skipped — could not resolve/verify the latest release binary for this platform yet; resolved lazily on launch."
    fi
    exit 0
  fi

  if [ -n "$tag" ] && bin="$(retrieve "$tag")" && [ -n "$bin" ]; then :
  elif bin="$(newest_cached_verified)" && [ -n "$bin" ]; then
    log "could not resolve the latest release (offline?) — using newest cached verified binary: ${bin}"
  elif bin="$(build_from_source)" && [ -n "$bin" ]; then :
  else
    log "could not obtain the flow-server binary for this platform ($(uname -sm 2>/dev/null))."
    log "expected a published release at https://github.com/${REPO}/releases/latest,"
    log "or a Rust toolchain (https://rustup.rs) for the source-build fallback."
    exit 1
  fi
  exec "$bin" "$@"
}

main "$@"
