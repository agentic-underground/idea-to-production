# ── DESTINATION: .cargo/config.toml ──────────────────────────────────────────
# GOVERNING DOC: knowledge/04-vercel-rust-runtime.md §5 + 06 B4
# This is NOT the workspace manifest (that's Cargo.toml). It provides the `cargo
# xtask` alias AND a mandatory empty [build] table workaround. DO NOT remove the
# [build] table — see the comment on it.
# ─────────────────────────────────────────────────────────────────────────────

[alias]
# `cargo xtask <cmd>` -> runs the xtask binary with <cmd> as argument.
# The xtask crate is the single source of truth for toolchain requirements.
#   cargo xtask setup    # install everything (idempotent)
#   cargo xtask check    # verify without installing
#   cargo xtask ci       # run the full GitHub Actions gate locally
#   cargo xtask serve    # dx serve with hot-reload
#   cargo xtask bundle <web|android|ios|all>
xtask = "run --package xtask --"

# GUARDRAIL — DO NOT REMOVE. Workaround for @vercel/rust 1.3.0: its builder reads
# this file and accesses `build.target` without guarding a missing [build] table,
# crashing the deploy with "Cannot read properties of undefined (reading 'target')".
# An empty [build] table (no target override) satisfies it without changing
# cargo's behaviour. Remove only once upstream guards the access.
[build]
