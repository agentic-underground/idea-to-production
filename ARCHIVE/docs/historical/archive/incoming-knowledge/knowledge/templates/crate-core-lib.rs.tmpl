// GOVERNING DOC: knowledge/02 §3 (tests-as-coordinates), 07 §2 (testing in practice)
// THE PURE DOMAIN CORE. No UI, no I/O, no platform code, NO unwrap/expect/panic
// outside tests. Errors are typed `thiserror` enums. This is the crate where the
// solution is LOCATED by coordinates (the tests below). Web, mobile, and the API
// all call this — so behaviour can never drift between platforms.
//
// This greeting domain is a worked example that proves the SHAPE end-to-end. When
// you build a real product: KEEP THE SHAPE, SWAP THE CONTENTS.
// ──────────────────────────────────────────────────────────────────────────────

use serde::{Deserialize, Serialize};

/// Errors the domain can produce. A real, typed error enum from day one — never
/// `String` errors, never `unwrap()` in library code. A `String` error cannot be
/// pinned precisely by a coordinate; a typed enum can. Review agents reject any PR
/// that introduces a panic path in this crate.
#[derive(Debug, Clone, PartialEq, Eq, thiserror::Error)]
pub enum GreetingError {
    /// The supplied name was empty or only whitespace.
    #[error("name must not be empty")]
    EmptyName,
    /// The supplied name exceeded the maximum supported length.
    #[error("name must be at most {max} characters, got {got}")]
    TooLong { max: usize, got: usize },
}

/// Maximum permitted greeting target length. Exposed so the UI can mirror the
/// limit in an input `maxlength` without duplicating the magic number.
pub const MAX_NAME_LEN: usize = 64;

/// A validated greeting target plus the rendered message.
///
/// Construction is fallible: you cannot build a `Greeting` in an invalid state.
/// This is the "parse, don't validate" pattern — once you hold a `Greeting`, the
/// invariants are guaranteed, so no downstream code needs to re-check them.
#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct Greeting {
    target: String,
}

impl Greeting {
    /// Create a greeting for `name`, trimming surrounding whitespace.
    ///
    /// # Errors
    /// Returns [`GreetingError::EmptyName`] if `name` is blank, or
    /// [`GreetingError::TooLong`] if it exceeds [`MAX_NAME_LEN`].
    pub fn new(name: &str) -> Result<Self, GreetingError> {
        let trimmed = name.trim();
        if trimmed.is_empty() {
            return Err(GreetingError::EmptyName);
        }
        // Count chars, not bytes: a 64-emoji name is 64 "characters" to a human.
        let len = trimmed.chars().count();
        if len > MAX_NAME_LEN {
            return Err(GreetingError::TooLong {
                max: MAX_NAME_LEN,
                got: len,
            });
        }
        Ok(Self {
            target: trimmed.to_owned(),
        })
    }

    /// The validated target.
    pub fn target(&self) -> &str {
        &self.target
    }

    /// The rendered greeting message. The single source of truth for the wording —
    /// web, mobile, and API all call this, so the product can never drift.
    pub fn message(&self) -> String {
        format!("Hello, {}! 🦀 {{project}} is live.", self.target)
    }
}

#[cfg(test)]
mod tests {
    // COORDINATES: each test below pins one point/region in the space of all
    // possible `Greeting` implementations. Together they leave exactly one correct
    // implementation. Write these FAILING first, then make them green (02 §3).
    use super::*;
    use proptest::prelude::*;

    #[test]
    fn greets_a_normal_name() {
        let g = Greeting::new("World").expect("valid");
        assert_eq!(g.target(), "World");
        assert_eq!(g.message(), "Hello, World! 🦀 {{project}} is live.");
    }

    #[test]
    fn trims_whitespace() {
        let g = Greeting::new("   Ada   ").expect("valid");
        assert_eq!(g.target(), "Ada");
    }

    #[test]
    fn rejects_empty() {
        assert_eq!(Greeting::new(""), Err(GreetingError::EmptyName));
        assert_eq!(Greeting::new("    "), Err(GreetingError::EmptyName));
    }

    #[test]
    fn rejects_too_long() {
        let long = "a".repeat(MAX_NAME_LEN + 1);
        assert_eq!(
            Greeting::new(&long),
            Err(GreetingError::TooLong {
                max: MAX_NAME_LEN,
                got: MAX_NAME_LEN + 1
            })
        );
    }

    #[test]
    fn accepts_exactly_max() {
        let exact = "a".repeat(MAX_NAME_LEN);
        assert!(Greeting::new(&exact).is_ok());
    }

    proptest! {
        // INVARIANT: any non-blank input within the length budget round-trips
        // through construction and always appears in the rendered message.
        #[test]
        fn valid_names_appear_in_message(name in "[^\\s]{1,64}") {
            let g = Greeting::new(&name).expect("valid by construction");
            prop_assert!(g.message().contains(g.target()));
        }

        // INVARIANT: construction never panics, for absolutely any string.
        #[test]
        fn never_panics(name in ".*") {
            let _ = Greeting::new(&name);
        }
    }
}
