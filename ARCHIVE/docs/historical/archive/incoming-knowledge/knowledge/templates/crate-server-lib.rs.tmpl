// HTTP-agnostic server glue. Thin by design: validates input via {{crate_prefix}}-core
// and shapes a JSON response. The HTTP plumbing lives in api/{{fn_name}}.rs (the
// Vercel function); this library holds the logic so it can be tested WITHOUT a
// network. Depends only on core (server -> core; never the reverse).
// ──────────────────────────────────────────────────────────────────────────────

use {{crate_prefix}}_core::Greeting;
use serde::Serialize;

/// The JSON payload returned by the greeting endpoint.
#[derive(Debug, Serialize, PartialEq, Eq)]
pub struct GreetResponse {
    pub ok: bool,
    pub message: String,
}

/// Produce a response for a requested name. Errors become a friendly `ok: false`
/// payload rather than a 500 — invalid input is a client concern, not a crash.
pub fn handle_greet(name: &str) -> GreetResponse {
    match Greeting::new(name) {
        Ok(g) => GreetResponse {
            ok: true,
            message: g.message(),
        },
        Err(e) => GreetResponse {
            ok: false,
            message: e.to_string(),
        },
    }
}

#[cfg(test)]
mod tests {
    // COORDINATES for the glue layer: the shape of the JSON contract and the
    // ok/not-ok decision are pinned here, against pure functions, no network.
    use super::*;

    #[test]
    fn ok_for_valid_name() {
        let r = handle_greet("Grace");
        assert!(r.ok);
        assert!(r.message.contains("Grace"));
    }

    #[test]
    fn graceful_for_empty() {
        let r = handle_greet("");
        assert!(!r.ok);
        assert_eq!(r.message, "name must not be empty");
    }

    #[test]
    fn serialises_to_expected_json_shape() {
        let json = serde_json::to_string(&handle_greet("Ada")).unwrap();
        assert!(json.contains("\"ok\":true"));
        assert!(json.contains("Ada"));
    }
}
