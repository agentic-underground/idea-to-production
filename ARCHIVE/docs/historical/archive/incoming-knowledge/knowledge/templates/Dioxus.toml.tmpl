# ── DESTINATION: Dioxus.toml (repo root) ─────────────────────────────────────
# GOVERNING DOC: knowledge/03 + 04. `dx serve` / `dx bundle` read this to know
# the web app's name, title, and asset/watch behaviour. Proven against Dioxus 0.7.
# ─────────────────────────────────────────────────────────────────────────────
[application]
name = "{{project}}"

[web.app]
title = "{{project}}"

[web.watcher]
reload_html = true
