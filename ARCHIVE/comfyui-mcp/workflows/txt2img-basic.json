{
  "_meta": {
    "template_id": "txt2img-basic",
    "description": "Allowlisted text-to-image workflow. submit_prompt fills ONLY: node 4 ckpt_name (∈ model allowlist), node 6 text (positive, length-capped), node 7 text (negative), node 3 seed/steps (bounded). No other node is fillable; no node is added or removed.",
    "fillable": {
      "4.inputs.ckpt_name": "model (∈ allowlist)",
      "6.inputs.text": "positive prompt (length-capped)",
      "7.inputs.text": "negative prompt (length-capped)",
      "3.inputs.seed": "seed (bounded)",
      "3.inputs.steps": "steps (bounded 1..50)"
    }
  },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0, "steps": 25, "cfg": 7.0, "sampler_name": "euler", "scheduler": "normal", "denoise": 1.0,
      "model": ["4", 0], "positive": ["6", 0], "negative": ["7", 0], "latent_image": ["5", 0]
    }
  },
  "4": { "class_type": "CheckpointLoaderSimple", "inputs": { "ckpt_name": "REPLACED_BY_SERVER" } },
  "5": { "class_type": "EmptyLatentImage", "inputs": { "width": 1024, "height": 1024, "batch_size": 1 } },
  "6": { "class_type": "CLIPTextEncode", "inputs": { "text": "REPLACED_BY_SERVER", "clip": ["4", 1] } },
  "7": { "class_type": "CLIPTextEncode", "inputs": { "text": "REPLACED_BY_SERVER", "clip": ["4", 1] } },
  "8": { "class_type": "VAEDecode", "inputs": { "samples": ["3", 0], "vae": ["4", 2] } },
  "9": { "class_type": "SaveImage", "inputs": { "filename_prefix": "publish", "images": ["8", 0] } }
}
