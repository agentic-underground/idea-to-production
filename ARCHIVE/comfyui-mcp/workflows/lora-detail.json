{
  "_meta": {
    "template_id": "lora-detail",
    "description": "Allowlisted txt2img with a 2-slot LoRA stack + latent hires-fix — the premium / dark-key-hero recipe (e.g. lowkey_v1.1 + LowRA). LoRAs chain 4->20->21 then feed the sampler; pass 2 (node 11) re-details the upscaled latent. To use one LoRA, set slot-2 strengths to 0. submit fills ONLY the listed nodes; _meta stripped before POST; lora_name in allowlist.",
    "fillable": {
      "4.inputs.ckpt_name": "model (in allowlist)",
      "20.inputs.lora_name": "LoRA #1 (in allowlist)",
      "20.inputs.strength_model": "LoRA #1 model strength (bounded 0..1.2)",
      "20.inputs.strength_clip": "LoRA #1 clip strength (bounded 0..1.2)",
      "21.inputs.lora_name": "LoRA #2 (in allowlist; set strengths 0 to disable)",
      "21.inputs.strength_model": "LoRA #2 model strength (bounded 0..1.2)",
      "21.inputs.strength_clip": "LoRA #2 clip strength (bounded 0..1.2)",
      "6.inputs.text": "positive prompt (length-capped)",
      "7.inputs.text": "negative prompt (length-capped)",
      "5.inputs.width": "base width (bounded 512..1536, step 8)",
      "5.inputs.height": "base height (bounded 512..1536, step 8)",
      "3.inputs.seed": "seed (bounded)",
      "3.inputs.steps": "pass-1 steps (1..50)",
      "3.inputs.cfg": "cfg (1..12)",
      "3.inputs.sampler_name": "sampler (in allowlist)",
      "3.inputs.scheduler": "scheduler (in allowlist)",
      "10.inputs.scale_by": "hires scale (1.0..2.0)",
      "11.inputs.denoise": "hires re-detail denoise (0.2..0.6)"
    }
  },
  "4": { "class_type": "CheckpointLoaderSimple", "inputs": { "ckpt_name": "REPLACED_BY_SERVER" } },
  "20": { "class_type": "LoraLoader", "inputs": { "lora_name": "REPLACED_BY_SERVER", "strength_model": 0.6, "strength_clip": 0.6, "model": ["4", 0], "clip": ["4", 1] } },
  "21": { "class_type": "LoraLoader", "inputs": { "lora_name": "REPLACED_BY_SERVER", "strength_model": 0.0, "strength_clip": 0.0, "model": ["20", 0], "clip": ["20", 1] } },
  "5": { "class_type": "EmptyLatentImage", "inputs": { "width": 1216, "height": 832, "batch_size": 1 } },
  "6": { "class_type": "CLIPTextEncode", "inputs": { "text": "REPLACED_BY_SERVER", "clip": ["21", 1] } },
  "7": { "class_type": "CLIPTextEncode", "inputs": { "text": "REPLACED_BY_SERVER", "clip": ["21", 1] } },
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0, "steps": 30, "cfg": 6.5, "sampler_name": "dpmpp_2m", "scheduler": "karras", "denoise": 1.0,
      "model": ["21", 0], "positive": ["6", 0], "negative": ["7", 0], "latent_image": ["5", 0]
    }
  },
  "10": { "class_type": "LatentUpscaleBy", "inputs": { "upscale_method": "nearest-exact", "scale_by": 1.5, "samples": ["3", 0] } },
  "11": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 0, "steps": 20, "cfg": 6.5, "sampler_name": "dpmpp_2m", "scheduler": "karras", "denoise": 0.45,
      "model": ["21", 0], "positive": ["6", 0], "negative": ["7", 0], "latent_image": ["10", 0]
    }
  },
  "8": { "class_type": "VAEDecode", "inputs": { "samples": ["11", 0], "vae": ["4", 2] } },
  "9": { "class_type": "SaveImage", "inputs": { "filename_prefix": "publish_lora", "images": ["8", 0] } }
}
