// GOVERNING DOC: knowledge/04-vercel-rust-runtime.md §3
// The Vercel serverless function. Runs on the hyper-based `vercel_runtime` 2.x
// (NOT 1.x — 1.x pulls lambda_runtime and panics on missing AWS_LAMBDA_* env
// vars; see 06 B3). This file is BORING on purpose: all decidable logic is in
// {{crate_prefix}}-server (which delegates to {{crate_prefix}}-core), fully
// unit-tested without a network. NO unwrap/expect/panic in the request path.
// ──────────────────────────────────────────────────────────────────────────────

use serde_json::json;
use vercel_runtime::{run, service_fn, Error, Request, Response, ResponseBody};

#[tokio::main]
async fn main() -> Result<(), Error> {
    // `run` internally wraps the handler in `service_fn`; pass the BARE handler.
    run(service_fn(handler)).await
}

async fn handler(req: Request) -> Result<Response<ResponseBody>, Error> {
    // Pull `name` out of the query string, defaulting to "World".
    let name = req
        .uri()
        .query()
        .and_then(|q| q.split('&').find_map(|kv| kv.strip_prefix("name=")))
        .map(urldecode)
        .unwrap_or_else(|| "World".to_string());

    // All logic lives in the server crate. Invalid input becomes a 400, not a panic.
    let payload = {{crate_prefix}}_server::handle_greet(&name);
    let status: u16 = if payload.ok { 200 } else { 400 };

    let response = Response::builder()
        .status(status)
        .header("Content-Type", "application/json")
        .body(ResponseBody::from(json!(payload).to_string()))?;

    Ok(response)
}

/// Minimal percent-decoding for the query value. Kept tiny and dependency-free;
/// swap for the `urlencoding` crate if you need full correctness on exotic input.
fn urldecode(s: &str) -> String {
    s.replace('+', " ").replace("%20", " ")
}
