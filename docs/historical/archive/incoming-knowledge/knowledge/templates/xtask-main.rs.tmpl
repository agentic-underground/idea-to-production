// GOVERNING DOC: knowledge/03-toolchain-and-environment.md §2
// The Rust-native toolchain manager — the SINGLE SOURCE OF TRUTH for this repo's
// toolchain. Invoked as `cargo xtask <command>` via the .cargo/config.toml alias.
// Pinned versions match the proven matrix (00-MANIFEST.md §4): zig 0.13.0, etc.
//
// xtask/Cargo.toml is a tiny std-only binary crate and a workspace member:
//   [package] name = "xtask"  version = "0.1.0"  edition.workspace = true  publish = false
//   (no dependencies)
// ──────────────────────────────────────────────────────────────────────────────
//! {{project}} xtask — Rust-native toolchain manager.
//!
//! # Commands
//! - `setup`         — install all required toolchain components (idempotent)
//! - `check`         — verify the toolchain without installing anything
//! - `ci`            — run the same gate as GitHub Actions (fmt + clippy + test + wasm)
//! - `serve`         — launch the web app with hot-reload via `dx serve`
//! - `bundle <tgt>`  — bundle a deployment target into `dist/<tgt>/`
//! - `help`          — print this list

use std::{
    env,
    process::{Command, ExitCode},
};

// ---------------------------------------------------------------------------
// Toolchain specification — the single source of truth for this repo's needs.
// ---------------------------------------------------------------------------

/// The WASM compilation target for all web artefacts.
const WASM_TARGET: &str = "wasm32-unknown-unknown";

/// Rustup components required beyond the default stable install.
const REQUIRED_COMPONENTS: &[&str] = &["rustfmt", "clippy"];

/// System packages required on Debian/Ubuntu for the native mobile target and the
/// GTK renderer backend used by Dioxus desktop/mobile. `libwebkit2gtk-4.1-dev`
/// ships on Debian 13 (Trixie) / Ubuntu 24.04+. `libxdo-dev` provides `-lxdo`.
const DEBIAN_PACKAGES: &[&str] = &[
    "libgtk-3-dev",
    "libwebkit2gtk-4.1-dev",
    "libglib2.0-dev",
    "libxdo-dev",
];

/// Cargo binaries that must be available on $PATH.
const REQUIRED_CARGO_BINS: &[(&str, &str)] = &[
    // (binary name, install crate)
    ("dx", "dioxus-cli"),
    // Used by Vercel's official Rust runtime builder (@vercel/rust) to
    // cross-compile the serverless function (api/{{fn_name}}.rs) during prebuilt
    // deploys. Needs `zig` too (see ZIG_VERSION).
    ("cargo-zigbuild", "cargo-zigbuild"),
];

/// Zig toolchain version installed for `cargo-zigbuild`. Pinned for reproducible
/// function builds.
const ZIG_VERSION: &str = "0.13.0";

/// Root directory for bundled deployment artefacts (`dist/web`, ...). Git-ignored.
const DIST_DIR: &str = "dist";

/// A bundleable deployment target driven by `dx bundle`.
struct BundleTarget {
    name: &'static str,
    platform: &'static str,
    package: &'static str,
}

/// Deployment targets `dx bundle` can build. `api/` is intentionally absent: the
/// Vercel function is built by @vercel/rust, not by `dx`.
const BUNDLE_TARGETS: &[BundleTarget] = &[
    BundleTarget {
        name: "web",
        platform: "web",
        package: "{{crate_prefix}}-web",
    },
    BundleTarget {
        name: "android",
        platform: "android",
        package: "{{crate_prefix}}-mobile",
    },
    BundleTarget {
        name: "ios",
        platform: "ios",
        package: "{{crate_prefix}}-mobile",
    },
];

// ---------------------------------------------------------------------------
// Entry point
// ---------------------------------------------------------------------------

fn main() -> ExitCode {
    let args: Vec<String> = env::args().collect();
    let cmd = args.get(1).map(String::as_str).unwrap_or("help");

    match cmd {
        "setup" => setup(),
        "check" => check(),
        "ci" => ci(),
        "serve" => serve(),
        "bundle" => bundle(args.get(2).map(String::as_str)),
        "help" | "--help" | "-h" => {
            print_help();
            ExitCode::SUCCESS
        }
        other => {
            eprintln!("xtask: unknown command '{other}'. Run `cargo xtask help`.");
            ExitCode::FAILURE
        }
    }
}

// ---------------------------------------------------------------------------
// Commands
// ---------------------------------------------------------------------------

fn setup() -> ExitCode {
    section("setup: installing {{project}} toolchain");

    let mut ok = true;

    step("rust toolchain (stable, pinned by rust-toolchain.toml)");
    ok &= run_ok("rustup", &["show", "active-toolchain"]);

    step(&format!("wasm target: {WASM_TARGET}"));
    ok &= run_ok("rustup", &["target", "add", WASM_TARGET]);

    for component in REQUIRED_COMPONENTS {
        step(&format!("component: {component}"));
        ok &= run_ok("rustup", &["component", "add", component]);
    }

    if is_debian_based() {
        let missing: Vec<&str> = DEBIAN_PACKAGES
            .iter()
            .copied()
            .filter(|pkg| !is_deb_installed(pkg))
            .collect();

        if missing.is_empty() {
            info("system packages: all present");
        } else {
            step(&format!("apt-get install: {}", missing.join(" ")));
            let mut apt_args = vec!["apt-get", "install", "-y"];
            apt_args.extend(missing.iter().copied());
            ok &= run_ok("sudo", &apt_args);
        }
    } else {
        warn("non-Debian system: skipping apt-get. Install GTK 3 + WebKit2GTK 4.1 manually.");
    }

    for (bin, krate) in REQUIRED_CARGO_BINS {
        if which(bin) {
            info(&format!("cargo bin: {bin} already installed"));
        } else {
            // `--locked` is mandatory: a bare `cargo install dioxus-cli` re-resolves
            // deps and pulls a `git2` that breaks `auth-git2`. The published
            // Cargo.lock is known-good. (See knowledge/06 A1.)
            step(&format!("cargo install {krate} --locked"));
            ok &= run_ok("cargo", &["install", krate, "--locked"]);
        }
    }

    ok &= install_zig();

    if ok {
        success("toolchain ready — run `cargo xtask check` to verify");
        ExitCode::SUCCESS
    } else {
        fail("one or more setup steps failed");
        ExitCode::FAILURE
    }
}

fn check() -> ExitCode {
    section("check: verifying {{project}} toolchain");

    let mut missing = Vec::new();

    if run_silent("rustc", &["--version"]) {
        let v = capture("rustc", &["--version"]).unwrap_or_default();
        info(&format!("rustc: {}", v.trim()));
    } else {
        missing.push("rustc (install via rustup.rs)");
    }

    let targets = capture("rustup", &["target", "list", "--installed"]).unwrap_or_default();
    if targets.contains(WASM_TARGET) {
        info(&format!("wasm target: {WASM_TARGET} ✓"));
    } else {
        missing.push(WASM_TARGET);
    }

    let components = capture("rustup", &["component", "list", "--installed"]).unwrap_or_default();
    for comp in REQUIRED_COMPONENTS {
        if components.contains(comp) {
            info(&format!("component: {comp} ✓"));
        } else {
            missing.push(comp);
        }
    }

    if is_debian_based() {
        for pkg in DEBIAN_PACKAGES {
            if is_deb_installed(pkg) {
                info(&format!("deb pkg: {pkg} ✓"));
            } else {
                missing.push(pkg);
            }
        }
    } else {
        for lib in &["glib-2.0", "gtk+-3.0"] {
            if run_silent("pkg-config", &[lib]) {
                info(&format!("pkg-config: {lib} ✓"));
            } else {
                missing.push(lib);
            }
        }
    }

    for (bin, _) in REQUIRED_CARGO_BINS {
        if which(bin) {
            let v = capture(bin, &["--version"]).unwrap_or_default();
            info(&format!("{bin}: {} ✓", v.trim()));
        } else {
            missing.push(bin);
        }
    }

    if which("zig") {
        let v = capture("zig", &["version"]).unwrap_or_default();
        info(&format!("zig: {} ✓", v.trim()));
    } else {
        missing.push("zig");
    }

    if missing.is_empty() {
        success("toolchain complete — all requirements satisfied");
        ExitCode::SUCCESS
    } else {
        fail("missing toolchain components:");
        for m in &missing {
            eprintln!("  - {m}");
        }
        eprintln!("  → run `cargo xtask setup` to install them");
        ExitCode::FAILURE
    }
}

fn ci() -> ExitCode {
    section("ci: running the GitHub Actions quality gate locally");

    let mut ok = true;

    step("cargo fmt --all -- --check");
    ok &= run_ok("cargo", &["fmt", "--all", "--", "--check"]);

    step("cargo clippy --workspace --all-targets -- -D warnings");
    ok &= run_ok(
        "cargo",
        &["clippy", "--workspace", "--all-targets", "--", "-D", "warnings"],
    );

    step("cargo test --workspace");
    ok &= run_ok("cargo", &["test", "--workspace"]);

    step(&format!("cargo build -p {{crate_prefix}}-web --target {WASM_TARGET} --release"));
    ok &= run_ok(
        "cargo",
        &["build", "-p", "{{crate_prefix}}-web", "--target", WASM_TARGET, "--release"],
    );

    if ok {
        success("CI gate: all checks passed");
        ExitCode::SUCCESS
    } else {
        fail("CI gate: one or more checks failed");
        ExitCode::FAILURE
    }
}

fn bundle(target: Option<&str>) -> ExitCode {
    section("bundle: building deployment artefacts into dist/<target>");

    if !which("dx") {
        fail("`dx` not found — run `cargo xtask setup` first");
        return ExitCode::FAILURE;
    }

    let selected: Vec<&BundleTarget> = match target {
        Some("all") => BUNDLE_TARGETS.iter().collect(),
        Some(name) => match BUNDLE_TARGETS.iter().find(|t| t.name == name) {
            Some(t) => vec![t],
            None => {
                fail(&format!("unknown bundle target '{name}'"));
                eprintln!("  valid targets: {}, all", bundle_target_names());
                return ExitCode::FAILURE;
            }
        },
        None => {
            fail("bundle requires a target");
            eprintln!("  usage: cargo xtask bundle <target>");
            eprintln!("  valid targets: {}, all", bundle_target_names());
            return ExitCode::FAILURE;
        }
    };

    let mut ok = true;
    for t in selected {
        let out_dir = format!("{DIST_DIR}/{}", t.name);
        step(&format!(
            "dx bundle --platform {} --package {} --release --out-dir {out_dir}",
            t.platform, t.package
        ));
        ok &= run_ok(
            "dx",
            &[
                "bundle", "--platform", t.platform, "--package", t.package, "--release",
                "--out-dir", &out_dir,
            ],
        );
    }

    if ok {
        success(&format!("bundle: artefacts written under {DIST_DIR}/"));
        ExitCode::SUCCESS
    } else {
        fail("bundle: one or more targets failed");
        ExitCode::FAILURE
    }
}

fn serve() -> ExitCode {
    section("serve: launching web app with hot-reload");
    if !which("dx") {
        fail("`dx` not found — run `cargo xtask setup` first");
        return ExitCode::FAILURE;
    }
    let err = exec("dx", &["serve"]);
    fail(&format!("failed to exec dx: {err}"));
    ExitCode::FAILURE
}

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

fn run_ok(cmd: &str, args: &[&str]) -> bool {
    Command::new(cmd)
        .args(args)
        .status()
        .unwrap_or_else(|e| panic!("failed to spawn `{cmd}`: {e}"))
        .success()
}

fn run_silent(cmd: &str, args: &[&str]) -> bool {
    Command::new(cmd)
        .args(args)
        .stdout(std::process::Stdio::null())
        .stderr(std::process::Stdio::null())
        .status()
        .map(|s| s.success())
        .unwrap_or(false)
}

fn capture(cmd: &str, args: &[&str]) -> Option<String> {
    let out = Command::new(cmd).args(args).output().ok()?;
    Some(String::from_utf8_lossy(&out.stdout).into_owned())
}

fn which(bin: &str) -> bool {
    Command::new("which")
        .arg(bin)
        .stdout(std::process::Stdio::null())
        .stderr(std::process::Stdio::null())
        .status()
        .map(|s| s.success())
        .unwrap_or(false)
}

fn is_debian_based() -> bool {
    std::path::Path::new("/etc/debian_version").exists()
}

/// Install the pinned Zig toolchain if it isn't already on `$PATH`. Zig is not a
/// cargo crate or a current apt package, so fetch the official release tarball.
/// Only Linux x86_64 is auto-installed; other hosts get a manual-install note.
fn install_zig() -> bool {
    if which("zig") {
        let v = capture("zig", &["version"]).unwrap_or_default();
        info(&format!("zig already installed: {}", v.trim()));
        return true;
    }

    if std::env::consts::OS != "linux" || std::env::consts::ARCH != "x86_64" {
        warn(&format!(
            "zig auto-install supports linux x86_64 only (host: {} {}). \
             Install zig {ZIG_VERSION}+ manually and put it on $PATH.",
            std::env::consts::OS,
            std::env::consts::ARCH
        ));
        return true;
    }

    let home = match std::env::var("HOME") {
        Ok(h) => h,
        Err(_) => {
            fail("cannot install zig: $HOME is not set");
            return false;
        }
    };

    let url =
        format!("https://ziglang.org/download/{ZIG_VERSION}/zig-linux-x86_64-{ZIG_VERSION}.tar.xz");
    let dist = format!("{home}/.local/zig-{ZIG_VERSION}");
    let tarball = format!("{dist}.tar.xz");
    let bin_dir = format!("{home}/.local/bin");
    let link = format!("{bin_dir}/zig");
    let target = format!("{dist}/zig");

    step(&format!("download + install zig {ZIG_VERSION}"));
    let _ = std::fs::create_dir_all(&dist);
    let _ = std::fs::create_dir_all(&bin_dir);

    if !run_ok("curl", &["-fsSL", "-o", &tarball, &url]) {
        fail("failed to download zig");
        return false;
    }
    if !run_ok("tar", &["-xf", &tarball, "-C", &dist, "--strip-components=1"]) {
        fail("failed to extract zig");
        return false;
    }
    let _ = std::fs::remove_file(&tarball);
    let _ = std::fs::remove_file(&link);
    if !run_ok("ln", &["-sf", &target, &link]) {
        fail("failed to symlink zig into ~/.local/bin");
        return false;
    }

    if which("zig") {
        let v = capture("zig", &["version"]).unwrap_or_default();
        info(&format!("zig installed: {}", v.trim()));
    } else {
        warn(&format!(
            "zig installed at {link}, but it is not on $PATH — add ~/.local/bin to PATH"
        ));
    }
    true
}

fn bundle_target_names() -> String {
    BUNDLE_TARGETS
        .iter()
        .map(|t| t.name)
        .collect::<Vec<_>>()
        .join(", ")
}

fn is_deb_installed(pkg: &str) -> bool {
    capture("dpkg-query", &["-W", "-f=${Status}", pkg])
        .unwrap_or_default()
        .contains("install ok installed")
}

#[cfg(unix)]
fn exec(cmd: &str, args: &[&str]) -> std::io::Error {
    use std::os::unix::process::CommandExt;
    Command::new(cmd).args(args).exec()
}

#[cfg(not(unix))]
fn exec(cmd: &str, args: &[&str]) -> std::io::Error {
    match Command::new(cmd).args(args).status() {
        Ok(_) => std::io::Error::new(std::io::ErrorKind::Other, "process exited"),
        Err(e) => e,
    }
}

// ---------------------------------------------------------------------------
// Output helpers
// ---------------------------------------------------------------------------

fn section(msg: &str) {
    println!("\n\x1b[1;34m══ {msg} ══\x1b[0m");
}
fn step(msg: &str) {
    println!("\x1b[1;33m  → {msg}\x1b[0m");
}
fn info(msg: &str) {
    println!("\x1b[90m  ✓ {msg}\x1b[0m");
}
fn success(msg: &str) {
    println!("\x1b[1;32m\n  ✓ {msg}\x1b[0m");
}
fn fail(msg: &str) {
    eprintln!("\x1b[1;31m\n  ✗ {msg}\x1b[0m");
}
fn warn(msg: &str) {
    println!("\x1b[1;33m  ⚠ {msg}\x1b[0m");
}

fn print_help() {
    println!(
        r#"
{{project}} xtask — dev-toolchain manager

USAGE
    cargo xtask <command>

COMMANDS
    setup   Install all required components (idempotent, safe to re-run)
    check   Verify every requirement is satisfied without installing anything
    ci      Run the full GitHub Actions quality gate locally
    serve   Launch the web app with hot-reload (wraps `dx serve`)
    bundle <web|android|ios|all>   Bundle a deployment target into dist/<target>/
    help    Print this message

NOTE: the Vercel function in api/ is built by Vercel's @vercel/rust runtime, not dx.
"#
    );
}
